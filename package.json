{
  "name": "standx-decibel-hedge",
  "version": "1.0.0",
  "description": "StandX × Decibel cross-exchange hedging volume bot",
  "main": "electron-main.js",
  "scripts": {
    "build": "tsc && cpx \"src/public/**/*\" dist/public",
    "start": "npm run build && electron .",
    "start:cli": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --mac --win --linux"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^1.33.1",
    "bs58": "^5.0.0",
    "ethers": "^6.13.0",
    "express": "^5.2.1",
"tweetnacl": "^1.0.3",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "cpx2": "^8.0.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.standx.hedge-bot",
    "productName": "StandX Hedge Bot",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "electron-main.js"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
